<?php
$vozila = ['Audi', 'BMW', 'Renault', 'Citroen'];
$odabrano = '';

if (isset($_POST['vozilo'])) {
    $odabrano = $_POST['vozilo'];
}
?>
<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="UTF-8">
    <title>Označi vozilo</title>
</head>
<body>
    <h2>Označi vozilo:</h2>

    <form method="POST">
        <?php foreach ($vozila as $v): ?>
            <label>
                <input type="radio" name="vozilo" value="<?= $v ?>"
                    <?= $odabrano === $v ? 'checked' : '' ?>>
                <?= $v ?>
            </label><br>
        <?php endforeach; ?>
        <br>
        <button type="submit">Pošalji</button>
    </form>

    <?php if ($odabrano !== ''): ?>
        <p>Odabrano vozilo: <strong><?= $odabrano ?></strong></p>
    <?php endif; ?>
</body>
</html>
